{
  "schema_version": 1,
  "seed_name": "codeblocks_stable_profile_seed",
  "source_files": [
    "default.conf",
    "default.cbKeyBinder20.conf",
    "codesnippets.ini"
  ],
  "managed_settings": {
    "preserve_pretty_printers": true,
    "preserve_keybindings": true,
    "preserve_snippets": true,
    "pin_compiler_and_debugger_paths": true,
    "support_targets": [
      "x86",
      "x64"
    ]
  },
  "debugger_init_commands": [
    "set pagination off",
    "set print pretty on",
    "set print elements 0",
    "set print max-depth 8",
    "set demangle-style gnu-v3",
    "set print object on",
    "set auto-load safe-path %ProgramFiles%\\CodeBlocks Stable Toolchain Edition\\MinGW\\share\\gcc-14.2.0\\python",
    "python",
    "import sys",
    "sys.path.insert(0, r\"%ProgramFiles%\\CodeBlocks Stable Toolchain Edition\\MinGW\\share\\gcc-14.2.0\\python\")",
    "from libstdcxx.v6.printers import register_libstdcxx_printers",
    "register_libstdcxx_printers(None)",
    "end"
  ]
}

