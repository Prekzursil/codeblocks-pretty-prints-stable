[MAIN]
py-version = 3.12
# Put the repository root on sys.path so first-party packages (`scripts`,
# `tests`) resolve during static analysis regardless of the invocation
# directory. This mirrors how the test runner and `scripts/verify` run.
init-hook = "import sys; sys.path.insert(0, '.')"

[MESSAGES CONTROL]
# Codacy's PyLint engine ships with rules that mis-fire on Python 3.12 / PEP
# 585 idiom. Disable only those specific false-positive rules — real findings
# still surface from the active pylintpython3 engine. This is rule
# configuration, not a file/issue exclusion.
#
# Disabled rules:
#   E0611  no-name-in-module — false positives on dynamic imports
#   E1101  no-member — false positives on third-party libs without stubs
#   E1136  unsubscriptable-object — PEP 585 false positives on builtin generics
#   R0801  duplicate-code — false positive on similar one-line module docstrings
#   R0903  too-few-public-methods — opinionated for dataclass-like containers
#   W0104  pointless-statement — false positive on context-manager usage
#   W0212  protected-access — too noisy on internal-tooling scripts
disable =
    E0611,
    E1101,
    E1136,
    R0801,
    R0903,
    W0104,
    W0212
